# API base (must match host that sets ACCESS_TOKEN / session cookies, e.g. http://localhost:8083/api)
VITE_API_BASE_URL=http://localhost:8080/api

# Cookie sessions: fetch uses credentials (default). Set to false only for same-origin APIs with no cookies.
# CORS must allow credentials + explicit origin when SPA and API differ (e.g. :5173 → :8083).
# VITE_API_WITH_CREDENTIALS=false

# Email/password login (POST). SSO uses VITE_SSO_* paths — not this one.
# VITE_AUTH_LOGIN_PATH=/auth/login
# If the API expects Spring-style { username, password }, set:
# VITE_AUTH_LOGIN_ID_FIELD=username

# Current-user endpoint after cookie session is established (backend redirect to SPA).
VITE_AUTH_ME_PATH=/auth/me

# POST — clears cookies; backend reads REFRESH_TOKEN from Cookie header for Keycloak logout.
# VITE_AUTH_LOGOUT_PATH=/auth/logout

VITE_RBAC_PERMISSIONS_PATH=/rbac/permissions
VITE_SSO_PROVIDERS_PATH=/auth/sso/providers
VITE_SSO_LOGIN_URL_PATH=/auth/sso/login-url
VITE_SSO_CALLBACK_PATH=/auth/sso/callback
# Keycloak public client id (must match resource_access.<client>.roles in the JWT)
VITE_KEYCLOAK_CLIENT_ID=hrapp
# Readable access-token cookie on SPA host → sent as Bearer to API (default ACCESS_TOKEN if unset).
# Set VITE_AUTH_TOKEN_COOKIE= to disable when using only API-host HttpOnly cookies.
# VITE_AUTH_TOKEN_COOKIE=ACCESS_TOKEN
# Legacy backends that expose GET /users/me instead of /auth/me:
# VITE_AUTH_ME_PATH=/users/me